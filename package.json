{
  "name": "mdasifbinkhaled.github.io",
  "version": "1.5.2",
  "description": "Academic portfolio showcasing research, publications, teaching activities, and professional experience",
  "author": {
    "name": "Md Asif Bin Khaled",
    "url": "https://mdasifbinkhaled.github.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mdasifbinkhaled/mdasifbinkhaled.github.io.git"
  },
  "bugs": {
    "url": "https://github.com/mdasifbinkhaled/mdasifbinkhaled.github.io/issues"
  },
  "homepage": "https://mdasifbinkhaled.github.io",
  "keywords": [
    "portfolio",
    "academic",
    "research",
    "nextjs",
    "typescript",
    "tailwindcss"
  ],
  "private": true,
  "engines": {
    "node": ">=22",
    "npm": ">=10.0.0 <12"
  },
  "packageManager": "npm@11.4.2",
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NEXT_TELEMETRY_DISABLED=1 next build",
    "build:production": "cross-env NEXT_TELEMETRY_DISABLED=1 NODE_ENV=production npm run build",
    "postbuild": "node -e \"const fs = require('fs'); fs.mkdirSync('out', { recursive: true }); fs.writeFileSync('out/.nojekyll', '');\" && node scripts/generate-service-worker.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mdx,css,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mdx,css,yaml,yml}\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json",
    "deadcode": "knip --no-progress",
    "analyze": "cross-env ANALYZE=true next build",
    "audit:ci": "npm audit --audit-level=high",
    "pre-commit": "lint-staged",
    "prepare": "husky",
    "clean": "rm -rf .next out coverage playwright-report test-results tsconfig*.tsbuildinfo .lighthouseci",
    "validate": "npm run lint:check && npm run format:check && npm run test:run && npm run typecheck",
    "validate:full": "npm run validate && npm run build && npx playwright test --project=chromium"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.6",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@sentry/browser": "^10.48.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "gray-matter": "^4.0.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.8.0",
    "next": "^16.2.6",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "read-excel-file": "^9.0.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.x",
    "@testing-library/react": "^16.x",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.15",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "knip": "^6.6.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "test-exclude": "8.0.0",
    "serialize-javascript": "7.0.5",
    "typescript-eslint": "8.59.0",
    "postcss": "$postcss",
    "eslint-plugin-react-hooks": "7.1.1"
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false,
    "quoteProps": "as-needed",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowParens": "always",
    "endOfLine": "lf",
    "embeddedLanguageFormatting": "auto",
    "htmlWhitespaceSensitivity": "css",
    "proseWrap": "preserve"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "tests/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,jsx}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,mdx}": [
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ],
    "*.{yaml,yml}": [
      "prettier --write"
    ]
  }
}
