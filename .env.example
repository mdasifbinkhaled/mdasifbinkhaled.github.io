# Environment Variables Template
# Copy this file to .env.local and fill in the appropriate values

# Site URL (for SEO and metadata)
NEXT_PUBLIC_SITE_URL=https://mdasifbinkhaled.github.io

# Development
NODE_ENV=development

# Analytics Configuration (Optional)
# Google Analytics 4 - Add your measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Enable/disable analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Error Tracking (Optional)
# Sentry DSN for client-side error reporting
NEXT_PUBLIC_SENTRY_DSN=
